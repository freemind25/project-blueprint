{
  "$schema": "https://raw.githubusercontent.com/nicedouble/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "UnRobot",
  "version": "0.1.0",
  "identifier": "com.unrobot.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:8080",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "UnRobot — AI Detection & Plagiarism Checker",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "fs": {
      "scope": {
        "allow": ["$HOME/**", "$DOCUMENT/**", "$DESKTOP/**", "$DOWNLOAD/**"],
        "deny": []
      }
    },
    "dialog": {
      "all": true,
      "open": true,
      "save": true
    },
    "shell": {
      "open": true,
      "scope": [
        {
          "name": "run-libreoffice",
          "cmd": "libreoffice",
          "args": true,
          "sidecar": false
        },
        {
          "name": "run-soffice",
          "cmd": "soffice",
          "args": true,
          "sidecar": false
        }
      ]
    }
  }
}