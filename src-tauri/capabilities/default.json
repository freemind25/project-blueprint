{
  "identifier": "default",
  "description": "UnRobot Desktop capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-read-dir",
    "fs:allow-exists",
    "fs:allow-stat",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-open-multiple",
    "dialog:allow-save",
    "shell:allow-open",
    "shell:allow-execute"
  ]
}